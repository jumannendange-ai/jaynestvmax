<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JaynesMaxTV" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#E50914</item>
        <item name="colorPrimaryVariant">#B00710</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#E50914</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">#0A0A0A</item>
        <item name="colorSurface">#111111</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.JaynesMaxTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.JaynesMaxTV</item>
    </style>

    <style name="Theme.JaynesMaxTV.Player" parent="Theme.JaynesMaxTV">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>
