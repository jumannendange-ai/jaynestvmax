<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"/>

    <!-- Loading -->
    <ProgressBar android:id="@+id/loadingBar"
        android:layout_width="56dp" android:layout_height="56dp"
        android:layout_gravity="center" android:indeterminate="true"
        android:indeterminateTint="#E8001D" android:visibility="gone"/>

    <!-- Top bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#88000000" android:paddingStart="12dp" android:paddingEnd="12dp">
        <ImageButton android:id="@+id/btnBack"
            android:layout_width="42dp" android:layout_height="42dp"
            android:background="@drawable/bg_plan_normal" android:src="@android:drawable/ic_media_previous"
            android:tint="@color/white" android:scaleType="center"/>
        <TextView android:id="@+id/txtChannelName"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="@color/white"
            android:textSize="16sp" android:textStyle="bold" android:letterSpacing="0.1"
            android:maxLines="1" android:ellipsize="end"
            android:paddingStart="12dp" android:paddingEnd="8dp"/>
        <TextView android:id="@+id/badgeLive"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" ● LIVE " android:textColor="@color/white" android:textSize="10sp"
            android:textStyle="bold" android:background="@drawable/bg_badge_live"
            android:layout_marginEnd="8dp" android:padding="4dp"/>
        <Button android:id="@+id/btnToggleStream"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:background="@drawable/bg_outline_btn" android:text="MPD"
            android:textColor="@color/red" android:textSize="11sp"
            android:textStyle="bold" android:visibility="gone"
            android:paddingStart="12dp" android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- Error overlay -->
    <LinearLayout android:id="@+id/errorLayout"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center"
        android:background="#CC000000" android:visibility="gone" android:padding="32dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📡" android:textSize="52sp" android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/txtError"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/muted" android:textSize="14sp"
            android:gravity="center" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btnRetry"
            android:layout_width="wrap_content" android:layout_height="46dp"
            android:background="@drawable/bg_red_btn" android:text="JARIBU TENA"
            android:textColor="@color/white" android:textSize="13sp"
            android:textStyle="bold" android:paddingStart="24dp" android:paddingEnd="24dp"/>
    </LinearLayout>

</FrameLayout>
