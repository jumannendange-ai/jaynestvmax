<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">

    <!-- Topbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/bg_topbar" android:paddingStart="14dp" android:paddingEnd="14dp">
        <ImageButton android:id="@+id/btnBack"
            android:layout_width="38dp" android:layout_height="38dp"
            android:background="@drawable/bg_plan_normal" android:src="@android:drawable/ic_media_previous"
            android:tint="@color/red" android:scaleType="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="AKAUNTI" android:textColor="@color/white"
            android:textSize="18sp" android:textStyle="bold" android:letterSpacing="0.15"
            android:paddingStart="12dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Profile circle -->
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_gravity="center" android:layout_marginBottom="16dp">
                <View android:layout_width="80dp" android:layout_height="80dp"
                    android:background="@drawable/circle_red"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:text="👤" android:textSize="32sp"/>
            </FrameLayout>

            <TextView android:id="@+id/txtName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"
                android:gravity="center" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/txtEmail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/muted" android:textSize="13sp"
                android:gravity="center" android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/txtPlanStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/green" android:textSize="14sp"
                android:textStyle="bold" android:gravity="center" android:layout_marginBottom="24dp"/>

            <!-- Sub card -->
            <LinearLayout android:id="@+id/subCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="16dp" android:layout_marginBottom="14dp" android:visibility="gone">
                <TextView android:id="@+id/txtSubEnd"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/muted" android:textSize="13sp"
                    android:layout_marginBottom="12dp"/>
                <Button android:id="@+id/btnMalipo"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_red_btn" android:text="LIPA SASA"
                    android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Logout -->
            <Button android:id="@+id/btnLogout"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_plan_normal" android:text="TOKA AKAUNTI"
                android:textColor="@color/muted" android:textSize="14sp" android:textStyle="bold"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
