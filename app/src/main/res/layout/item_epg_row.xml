<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="8dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tvChannelName"
        android:layout_width="100dp" android:layout_height="wrap_content"
        android:textColor="#FFFFFF" android:textSize="13sp"
        android:textStyle="bold" android:maxLines="2"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvProgrammes"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal"/>
</LinearLayout>
