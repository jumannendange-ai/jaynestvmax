<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="120dp" android:layout_height="90dp"
    android:orientation="vertical" android:gravity="center"
    android:background="#1A1A1A" android:layout_margin="4dp">
    <ImageView android:id="@+id/ivChannelLogo"
        android:layout_width="50dp" android:layout_height="50dp"
        android:scaleType="centerCrop"/>
    <TextView android:id="@+id/tvChannelName"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#FFFFFF" android:textSize="10sp"
        android:gravity="center" android:maxLines="1" android:layout_marginTop="2dp"/>
    <TextView android:id="@+id/tvLiveBadge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="LIVE" android:textColor="#FFFFFF" android:textSize="8sp"
        android:background="#E50914" android:paddingHorizontal="4dp"
        android:visibility="gone"/>
</LinearLayout>
