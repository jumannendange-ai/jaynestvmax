<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">
        <ImageButton android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chagua Mpango"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPlans"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>
    <RadioGroup android:id="@+id/rgPayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">
        <RadioButton android:id="@+id/rbMpesa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="M-Pesa"
            android:textColor="#FFFFFF"
            android:checked="true"/>
        <RadioButton android:id="@+id/rbTigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tigo"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp"/>
        <RadioButton android:id="@+id/rbAirtel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Airtel"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp"/>
    </RadioGroup>
    <EditText android:id="@+id/etPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nambari ya simu (07xx...)"
        android:inputType="phone"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:padding="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"/>
    <Button android:id="@+id/btnPay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="CHAGUA MPANGO KWANZA"
        android:backgroundTint="#E50914"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_margin="12dp"
        android:enabled="false"/>
</LinearLayout>
