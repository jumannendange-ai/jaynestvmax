<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="80dp" android:layout_height="70dp"
    android:orientation="vertical" android:gravity="center"
    android:background="@drawable/bg_method_normal"
    android:layout_margin="5dp" android:padding="8dp">
    <TextView android:id="@+id/txtMethodIcon"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="24sp" android:layout_marginBottom="4dp"/>
    <TextView android:id="@+id/txtMethodName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/muted" android:textSize="9sp"
        android:textStyle="bold" android:gravity="center" android:maxLines="1"/>
</LinearLayout>
