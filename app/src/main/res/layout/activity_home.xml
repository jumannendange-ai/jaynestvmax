<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- SCROLL CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="60dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- LIVE label -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="● INAYOENDELEA"
                android:textColor="@color/muted" android:textSize="11sp"
                android:letterSpacing="0.15" android:paddingStart="14dp"
                android:paddingEnd="14dp" android:paddingTop="12dp" android:paddingBottom="6dp"/>

            <!-- SLIDER (ViewPager2) -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpSlider"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:clipToPadding="false"/>

            <!-- Dots indicator -->
            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                android:id="@+id/dotsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                app:dotsColor="@color/red"
                app:dotsSize="6dp"
                app:dotsSpacing="4dp"
                app:selectedDotColor="@color/red"/>

            <!-- QUICK BUTTONS label -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="HARAKA" android:textColor="@color/muted" android:textSize="11sp"
                android:letterSpacing="0.15" android:paddingStart="14dp"
                android:paddingEnd="14dp" android:paddingTop="10dp" android:paddingBottom="6dp"/>

            <!-- QUICK BUTTONS row -->
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingBottom="8dp" android:clipToPadding="false">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">

                    <LinearLayout android:id="@+id/btnMechi" android:layout_width="68dp"
                        android:layout_height="72dp" android:orientation="vertical"
                        android:gravity="center" android:background="@drawable/bg_quick_btn"
                        android:layout_marginEnd="8dp" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚽" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mechi" android:textColor="@color/muted" android:textSize="10sp"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnAzam" android:layout_width="68dp"
                        android:layout_height="72dp" android:orientation="vertical"
                        android:gravity="center" android:background="@drawable/bg_quick_btn"
                        android:layout_marginEnd="8dp" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📡" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Azam" android:textColor="@color/muted" android:textSize="10sp"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnNBC" android:layout_width="68dp"
                        android:layout_height="72dp" android:orientation="vertical"
                        android:gravity="center" android:background="@drawable/bg_quick_btn"
                        android:layout_marginEnd="8dp" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📺" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="NBC" android:textColor="@color/muted" android:textSize="10sp"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnGlobal" android:layout_width="68dp"
                        android:layout_height="72dp" android:orientation="vertical"
                        android:gravity="center" android:background="@drawable/bg_quick_btn"
                        android:layout_marginEnd="8dp" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌐" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Global" android:textColor="@color/muted" android:textSize="10sp"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnLocal" android:layout_width="68dp"
                        android:layout_height="72dp" android:orientation="vertical"
                        android:gravity="center" android:background="@drawable/bg_quick_btn"
                        android:layout_marginEnd="8dp" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📻" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Local" android:textColor="@color/muted" android:textSize="10sp"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnMalipo" android:layout_width="68dp"
                        android:layout_height="72dp" android:orientation="vertical"
                        android:gravity="center" android:background="@drawable/bg_quick_btn"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💳" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Malipo" android:textColor="@color/muted" android:textSize="10sp"
                            android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- TRIAL BANNER -->
            <LinearLayout android:id="@+id/trialBanner"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bg_trial_banner"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="10dp" android:paddingBottom="10dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textColor="@color/text" android:textSize="12sp">
                    <![CDATA[● Majaribio: ]]>
                </TextView>
                <TextView android:id="@+id/txtTrialTime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="30:00" android:textColor="@color/red"
                    android:textSize="18sp" android:textStyle="bold" android:layout_marginEnd="12dp"/>
                <Button android:id="@+id/btnTrialUpgrade"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:background="@drawable/bg_red_btn" android:text="PATA PREMIUM"
                    android:textColor="@color/white" android:textSize="11sp"
                    android:textStyle="bold" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            </LinearLayout>

            <!-- PAYWALL BANNER -->
            <LinearLayout android:id="@+id/paywallBanner"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_paywall_banner"
                android:padding="16dp" android:layout_marginBottom="4dp"
                android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔒 Muda wa majaribio umeisha"
                    android:textColor="@color/text" android:textSize="14sp"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Jiunge premium ili uendelee kutazama channels zote"
                    android:textColor="@color/muted" android:textSize="12sp"
                    android:gravity="center" android:layout_marginBottom="12dp"/>
                <Button android:id="@+id/btnPaywallLipa"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="@drawable/bg_red_btn" android:text="💳  LIPA SASA — ANGALIA MIPANGO"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- CHANNELS label -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="🏆 CHANNELS" android:textColor="@color/muted" android:textSize="11sp"
                android:letterSpacing="0.15" android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="10dp" android:paddingBottom="6dp"/>

            <!-- Shimmer placeholder -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerChannels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:visibility="visible">
                <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:columnCount="2" android:rowCount="3" android:useDefaultMargins="true">
                    <!-- 6 placeholder cards -->
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_columnWeight="1" android:background="@drawable/bg_card" android:layout_margin="5dp"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_columnWeight="1" android:background="@drawable/bg_card" android:layout_margin="5dp"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_columnWeight="1" android:background="@drawable/bg_card" android:layout_margin="5dp"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_columnWeight="1" android:background="@drawable/bg_card" android:layout_margin="5dp"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_columnWeight="1" android:background="@drawable/bg_card" android:layout_margin="5dp"/>
                    <View android:layout_width="0dp" android:layout_height="120dp"
                        android:layout_columnWeight="1" android:background="@drawable/bg_card" android:layout_margin="5dp"/>
                </GridLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- CHANNELS RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChannels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

            <!-- ERROR -->
            <LinearLayout android:id="@+id/errorLayout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center"
                android:padding="48dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📡" android:textSize="48sp" android:layout_marginBottom="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hakuna mtandao" android:textColor="@color/muted"
                    android:textSize="14sp" android:layout_marginBottom="16dp"/>
                <Button android:id="@+id/btnRetryLoad"
                    android:layout_width="wrap_content" android:layout_height="44dp"
                    android:background="@drawable/bg_outline_btn" android:text="JARIBU TENA"
                    android:textColor="@color/red" android:textSize="13sp" android:textStyle="bold"
                    android:paddingStart="24dp" android:paddingEnd="24dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- TOP BAR (fixed) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/bg_topbar" android:paddingStart="14dp" android:paddingEnd="14dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="▶ JAYNES" android:textColor="@color/white"
            android:textSize="20sp" android:textStyle="bold" android:letterSpacing="0.15"
            android:layout_marginEnd="10dp"/>
        <FrameLayout android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
            android:background="@drawable/bg_input">
            <EditText android:id="@+id/inputSearch"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@null" android:padding="10dp" android:hint="Tafuta channels..."
                android:hintTextColor="@color/muted" android:textColor="@color/text"
                android:textSize="13sp" android:imeOptions="actionSearch" android:singleLine="true"/>
        </FrameLayout>
    </LinearLayout>

    <!-- BOTTOM NAV (fixed) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nyumbani" android:textColor="@color/red" android:textSize="10sp"
                android:textStyle="bold" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navLive" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶" android:textSize="20sp" android:textColor="@color/muted"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Live" android:textColor="@color/muted" android:textSize="10sp"
                android:textStyle="bold" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navMalipo" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💳" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Malipo" android:textColor="@color/muted" android:textSize="10sp"
                android:textStyle="bold" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAkaunti" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Akaunti" android:textColor="@color/muted" android:textSize="10sp"
                android:textStyle="bold" android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
